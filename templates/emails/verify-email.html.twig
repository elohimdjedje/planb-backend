{% extends 'emails/base.html.twig' %}

{% block content %}
    <h1 style="color: #FF6B35; margin-top: 0;">Vérifiez votre adresse email</h1>
    
    <p>Bonjour <strong>{{ user.firstName }}</strong>,</p>
    
    <p>Vous avez demandé à vérifier votre adresse email sur Plan B.</p>
    
    <p>Cliquez sur le bouton ci-dessous pour confirmer votre adresse email :</p>
    
    <div style="text-align: center;">
        <a href="{{ verificationUrl }}" class="button">Vérifier mon email</a>
    </div>
    
    <p style="font-size: 14px; color: #666;">
        Ou copiez ce lien dans votre navigateur :<br>
        <a href="{{ verificationUrl }}" style="color: #FF6B35; word-break: break-all;">{{ verificationUrl }}</a>
    </p>
    
    <p><strong>Ce lien expire dans 24 heures.</strong></p>
    
    <p>Si vous n'avez pas demandé cette vérification, vous pouvez ignorer cet email en toute sécurité.</p>
    
    <p>Cordialement,<br><strong>L'équipe Plan B</strong></p>
{% endblock %}
