# Configuration de l'environnement
APP_ENV=dev
# SECURITY: Régénérer ce secret en production avec une valeur aléatoire unique
APP_SECRET=CHANGEZ_MOI_AVEC_VALEUR_ALEATOIRE_32_CARACTERES

# Base de données PostgreSQL (Docker)
# Utiliser 'database' comme nom d'hôte dans Docker, ou 'localhost' si backend hors Docker
DATABASE_URL="postgresql://postgres:root@database:5432/planb?serverVersion=15&charset=utf8"

# JWT Authentication (IMPORTANT: Générer les clés avec: php bin/console lexik:jwt:generate-keypair)
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
# SECURITY: Régénérer ce passphrase en production avec une valeur aléatoire unique
JWT_PASSPHRASE=CHANGEZ_MOI_AVEC_VALEUR_ALEATOIRE_64_CARACTERES
JWT_TTL=3600

# CORS - Domaines autorisés (frontend)
# PRODUCTION: Restreindre aux domaines spécifiques, ex: ^https://(www\.)?votredomaine\.com$
CORS_ALLOW_ORIGIN=^https?://(localhost|127\.0\.0\.1|192\.168\.1\.176)(:[0-9]+)?$

# Cloudinary (recommandé pour stockage images)
# Inscription gratuite sur https://cloudinary.com
CLOUDINARY_CLOUD_NAME=votre_cloud_name
CLOUDINARY_API_KEY=votre_api_key
CLOUDINARY_API_SECRET=votre_api_secret

# OU AWS S3 (alternative)
# AWS_ACCESS_KEY_ID=votre_access_key
# AWS_SECRET_ACCESS_KEY=votre_secret_key
# AWS_S3_BUCKET=planb-uploads
# AWS_REGION=eu-west-1

# ============================================
# PAIEMENTS - PayTech + KKiaPay uniquement
# ============================================

# KKiaPay (Agrégateur de paiement Mobile Money - Wave, Orange Money, MTN, Moov)
# Inscription sur https://kkiapay.me
KKIAPAY_PUBLIC_KEY=127ea3a40f8a7a2d07f7f2fca1baddc43baf7e99
KKIAPAY_PRIVATE_KEY=pk_d97036809f2796720e001d33abbecesa9d0e0a42bf6oad0204e13c003f8533e11
KKIAPAY_SECRET=sk_3ef5006eebb4a6c1b817c82f581695c16ba8bc1c361a621ba747559c396a3851
KKIAPAY_SANDBOX=false
KKIAPAY_CALLBACK_URL=http://localhost:8000/api/webhook/kkiapay

# PayTech (Agrégateur de paiement - Wave, Orange Money, Free Money, Carte)
# Inscription sur https://paytech.sn
PAYTECH_API_KEY=c68dfb7a280e0dd87efa7cfc789c7b460ded83c8c4400d0057ad5661d024f10b
PAYTECH_SECRET_KEY=3bc81369528b8078033011372133d691d9c3ef3489c920b6938247e777112adb
PAYTECH_ENV=test
# URLs de redirection PayTech (à modifier en production)
PAYTECH_IPN_URL=http://localhost:8000/api/webhook/paytech
PAYTECH_SUCCESS_URL=http://localhost:5173/payments/success
PAYTECH_CANCEL_URL=http://localhost:5173/payments/cancel

# URL de l'application
APP_URL=http://localhost:8000
# URL du frontend web (liens mail / SMS abonnement → /upgrade)
FRONTEND_URL=http://localhost:5173

# WhatsApp support (lien wa.me dans les mails/SMS d’expiration PRO, sans API)
# Format international, ex: +2250700000000
ADMIN_WHATSAPP_PHONE=+2250000000000

# SMS Configuration (Twilio ou autre provider)
SMS_PROVIDER=twilio
TWILIO_SID=your_twilio_sid
TWILIO_TOKEN=your_twilio_token
TWILIO_FROM=+1234567890

# Email (optionnel pour phase de dev)
# MAILER_DSN=smtp://localhost:1025
# Pour production, utilisez Brevo (gratuit) ou SendGrid
# MAILER_DSN=smtp://apikey:votre_key@smtp.sendgrid.net:587

# Configuration limites
MAX_IMAGES_FREE=3
MAX_IMAGES_PRO=10
LISTING_DURATION_FREE=30
LISTING_DURATION_PRO=90

# Prix abonnement PRO (en XOF - Francs CFA)
PRO_SUBSCRIPTION_PRICE=10000

# Environnement de développement
###> symfony/framework-bundle ###
###< symfony/framework-bundle ###

###> nelmio/cors-bundle ###
###< nelmio/cors-bundle ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
###< doctrine/doctrine-bundle ###

###> lexik/jwt-authentication-bundle ###
###< lexik/jwt-authentication-bundle ###

###> symfony/mailer ###
MAILER_DSN=null://null
###< symfony/mailer ###

###> symfony/lock ###
# Choose one of the stores below
# postgresql+advisory://db_user:db_password@localhost/db_name
LOCK_DSN=flock
###< symfony/lock ###
